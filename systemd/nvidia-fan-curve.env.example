# GPU index from nvidia-smi (usually 0 for single-GPU systems)
GPU_INDEX=0

# X display that exposes NV-CONTROL for your NVIDIA GPU.
# :0.0 is the standard value for the first screen on desktop Xorg/Wayland.
DISPLAY_NUM=:0

# Xauthority cookie path for the selected display.
# Leave empty to let nvidia-settings use its default.
XAUTHORITY_PATH=
